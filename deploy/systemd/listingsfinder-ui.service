[Unit]
Description=ListingsFinder AI Streamlit UI
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/listingsfinder-ai
EnvironmentFile=/opt/listingsfinder-ai/.env
ExecStart=/opt/listingsfinder-ai/.venv/bin/streamlit run app.py --server.port 8501 --server.address 0.0.0.0
Restart=always
RestartSec=10
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target